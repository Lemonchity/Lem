-- Конфигурация
local CorrectKey = "CesyncLemCTR-282-RTH-9H1"
local DiscordLink = "https://discord.gg/aZ6sGrXgb"

-- Создание графического интерфейса
local ScreenGui = Instance.new("ScreenGui")
local MainFrame = Instance.new("Frame")
local Title = Instance.new("TextLabel")
local KeyInput = Instance.new("TextBox")
local SubmitBtn = Instance.new("TextButton")
local GetKeyBtn = Instance.new("TextButton")

-- Настройка ScreenGui
ScreenGui.Name = "CeSync_Rounded_Auth"
ScreenGui.Parent = game:GetService("CoreGui")
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

-- Функция для быстрого создания скругленных углов
local function RoundElement(element, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 12) -- Радиус скругления
    corner.Parent = element
end

-- Основное окно
MainFrame.Name = "MainFrame"
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
MainFrame.Position = UDim2.new(0.5, -125, 0.5, -90)
MainFrame.Size = UDim2.new(0, 250, 0, 180)
MainFrame.BorderSizePixel = 0
RoundElement(MainFrame, 15) -- Сильное скругление для окна

-- Заголовок
Title.Parent = MainFrame
Title.Size = UDim2.new(1, 0, 0, 45)
Title.Text = "CESYNC EXECUTOR"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.BackgroundTransparency = 1
Title.Font = Enum.Font.GothamBold
Title.TextSize = 18

-- Поле ввода ключа
KeyInput.Parent = MainFrame
KeyInput.Position = UDim2.new(0.1, 0, 0.3, 0)
KeyInput.Size = UDim2.new(0.8, 0, 0, 35)
KeyInput.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
KeyInput.Text = ""
KeyInput.PlaceholderText = "Paste Key Here..."
KeyInput.TextColor3 = Color3.fromRGB(255, 255, 255)
KeyInput.Font = Enum.Font.Gotham
KeyInput.TextSize = 14
KeyInput.BorderSizePixel = 0
RoundElement(KeyInput, 8) -- Скругление для поля ввода

-- Кнопка CHECK KEY
SubmitBtn.Parent = MainFrame
SubmitBtn.Position = UDim2.new(0.1, 0, 0.55, 0)
SubmitBtn.Size = UDim2.new(0.8, 0, 0, 32)
SubmitBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
SubmitBtn.Text = "CHECK KEY"
SubmitBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
SubmitBtn.Font = Enum.Font.GothamBold
SubmitBtn.TextSize = 14
SubmitBtn.BorderSizePixel = 0
RoundElement(SubmitBtn, 10) -- Скругление для кнопки

-- Кнопка GET KEY
GetKeyBtn.Parent = MainFrame
GetKeyBtn.Position = UDim2.new(0.1, 0, 0.77, 0)
GetKeyBtn.Size = UDim2.new(0.8, 0, 0, 32)
GetKeyBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
GetKeyBtn.Text = "GET KEY (DISCORD)"
GetKeyBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
GetKeyBtn.Font = Enum.Font.GothamBold
GetKeyBtn.TextSize = 14
GetKeyBtn.BorderSizePixel = 0
RoundElement(GetKeyBtn, 10) -- Скругление для кнопки

-- Логика копирования ссылки
GetKeyBtn.MouseButton1Click:Connect(function()
    if setclipboard then
        setclipboard(DiscordLink)
        local originalText = GetKeyBtn.Text
        GetKeyBtn.Text = "LINK COPIED!"
        GetKeyBtn.TextColor3 = Color3.fromRGB(0, 255, 127)
        wait(1.5)
        GetKeyBtn.Text = originalText
        GetKeyBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
end)

-- Логика авторизации и запуска лоадера
SubmitBtn.MouseButton1Click:Connect(function()
    if KeyInput.Text == CorrectKey then
        SubmitBtn.Text = "ACCESS GRANTED"
        SubmitBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 80)
        wait(1)
        ScreenGui:Destroy()
        
        -- Выполнение твоего loadstring
        loadstring(game:HttpGet("https://raw.githubusercontent.com/Lemonchity/CeSync/refs/heads/main/OneTap"))()
    else
        SubmitBtn.Text = "INVALID KEY"
        SubmitBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        KeyInput.Text = ""
        wait(1.5)
        SubmitBtn.Text = "CHECK KEY"
        SubmitBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
    end
end)
